# Port the server listens on (Railway/Render set PORT automatically)
PORT=3001

# Override binary paths if yt-dlp / ffmpeg are not on PATH
# YT_DLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_PATH=/usr/bin/ffmpeg

# Where converted mp3s are cached (defaults to the OS temp dir)
# CACHE_DIR=/tmp/cadence-audio-cache
